{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/login", "destination": "/auth.html?form=login" },
    { "source": "/signup", "destination": "/auth.html?form=signup" },
    { "source": "/admin-dashboard", "destination": "/admin-dashboard.html" },
    { "source": "/host-dashboard", "destination": "/host-dashboard-upgraded.html" },
    { "source": "/support-dashboard", "destination": "/support-dashboard-upgraded.html" },
    { "source": "/customer-dashboard", "destination": "/customer-dashboard.html" },
    { "source": "/property/:id", "destination": "/property-view.html" },
    { "source": "/add-property", "destination": "/add-property.html" },
    { "source": "/property-listing", "destination": "/property-listing.html" },
    { "source": "/live-tours", "destination": "/live-tours.html" },
    { "source": "/help", "destination": "/help.html" },
    { "source": "/wishlist", "destination": "/wishlist.html" },
    { "source": "/messages", "destination": "/messages.html" },
    { "source": "/profile", "destination": "/profile.html" },
    { "source": "/settings", "destination": "/settings.html" },
    { "source": "/customers", "destination": "/customer-dashboard.html" },
    { "source": "/platform-master-hub/login", "destination": "/platform-master-hub/signup.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer-when-downgrade" },
        { "key": "Permissions-Policy", "value": "geolocation=(), camera=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; connect-src 'self' https: wss:; frame-ancestors 'none'; base-uri 'self';" }
      ]
    }
  ]
}
