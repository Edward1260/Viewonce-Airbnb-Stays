{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:simple": "nest start --entryFile main-simple",
    "start:minimal": "nest start --entryFile main-minimal",
    "start:no-db": "nest start --entryFile main-no-db",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "typeorm migration:generate -d dist/config/database.config.js",
    "migration:create": "typeorm migration:create -d dist/config/database.config.js",
    "migration:run": "typeorm migration:run -d dist/config/database.config.js",
    "migration:revert": "typeorm migration:revert -d dist/config/database.config.js",
    "migration:show": "typeorm migration:show -d dist/config/database.config.js"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.14",
    "@nestjs/platform-socket.io": "^11.1.14",
    "socket.io": "^4.8.1",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^6.0.0",
    "cache-manager": "^6.0.0",
    "cache-manager-ioredis": "^2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "stripe": "^20.1.2",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "viewonce-airbnb-stays": "file:.."
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@types/multer": "^1.4.13",
    "@types/socket.io": "^3.0.2"
  }
}
