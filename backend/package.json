{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "start:simple": "nest start --entryFile main-simple",
    "start:minimal": "nest start --entryFile main-minimal",
    "start:no-db": "nest start --entryFile main-no-db",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "typeorm migration:generate -d dist/config/database.config.js",
    "migration:create": "typeorm migration:create -d dist/config/database.config.js",
    "migration:run": "typeorm migration:run -d dist/config/database.config.js",
    "migration:revert": "typeorm migration:revert -d dist/config/database.config.js",
    "migration:show": "typeorm migration:show -d dist/config/database.config.js"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "@nestjs/cache-manager": "^2.2.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^10.2.2",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.4.4",
    "@nestjs/terminus": "^4.0.0",
    "@nestjs/throttler": "^6.1.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.4",
    "@nestjs/platform-socket.io": "^10.4.4",
    "cache-manager-redis-store": "^3.1.1",
    "qrcode": "^1.5.3",
    "socket.io": "^4.8.1",
    "speakeasy": "^2.0.0",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^6.0.0",
    "cache-manager": "^5.0.0",
    "cache-manager-ioredis": "^5.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "stripe": "^20.1.2",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.4",
    "@nestjs/testing": "^10.4.4",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.4",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^6.0.2",
    "eslint": "^8.57.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": "^20.0.0"
  }
}
