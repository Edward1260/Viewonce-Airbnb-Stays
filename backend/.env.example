# =============================================================================
# Application Configuration
# =============================================================================

# Application Environment
NODE_ENV=development  # development | staging | production

# Application Port
PORT=3001

# Application URL (for CORS and links)
APP_URL=http://localhost:3001

# =============================================================================
# Database Configuration
# =============================================================================

# Database Type: sqlite | postgres
DB_TYPE=sqlite

# SQLite (development)
DB_DATABASE=db.sqlite

# PostgreSQL (production) - Set DB_TYPE=postgres to use
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=your_password_here
# DB_DATABASE=airbnb_db

# Connection Pool Settings (for PostgreSQL)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# =============================================================================
# Authentication
# =============================================================================

# JWT Secret - CHANGE THIS IN PRODUCTION!
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT Expiration
JWT_EXPIRATION=7d

# =============================================================================
# Cache Configuration
# =============================================================================

# Cache Driver: memory | redis
CACHE_DRIVER=memory

# Redis Configuration (when CACHE_DRIVER=redis)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# =============================================================================
# Redis Configuration (for caching and sessions)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# Elasticsearch Configuration
# =============================================================================
ELASTICSEARCH_HOST=http://localhost
ELASTICSEARCH_PORT=9200

# =============================================================================
# Stripe Payment Configuration
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# File Upload Configuration
# =============================================================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes

# =============================================================================
# Rate Limiting
# =============================================================================
THROTTLE_TTL=60000  # 1 minute in milliseconds
THROTTLE_LIMIT=100  # requests per TTL

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:9002

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=debug  # debug | info | warn | error
LOG_COLORIZE=true

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_REALTIME=true

# =============================================================================
# Security
# =============================================================================
BCRYPT_ROUNDS=10

# =============================================================================
# Email Configuration (for notifications)
# =============================================================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password
# SMTP_FROM=noreply@example.com

# =============================================================================
# Monitoring & Health Checks
# =============================================================================
HEALTH_CHECK_DETAILED=true
METRICS_ENABLED=true
